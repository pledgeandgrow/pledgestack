// app/api/users/route.ps — pure Rust API route, no React/JSX

use sqlx::PgPool;
use serde::Serialize;

#[derive(Serialize)]
pub struct User {
    pub id: i32,
    pub name: String,
    pub email: String,
    pub role: Option<String>,
}

/// Fetch all users with optional limit
pub async fn get_users(pool: &PgPool, limit: i32) -> Vec<User> {
    sqlx::query_as!(
        User,
        "SELECT id, name, email, role FROM users ORDER BY id LIMIT $1",
        limit
    )
    .fetch_all(pool)
    .await
}

/// Get a single user by ID
pub async fn get_user_by_id(pool: &PgPool, id: i32) -> Option<User> {
    sqlx::query_as!(
        User,
        "SELECT id, name, email, role FROM users WHERE id = $1",
        id
    )
    .fetch_optional(pool)
    .await
}

/// Create a new user
pub async fn create_user(pool: &PgPool, name: String, email: String) -> User {
    sqlx::query_as!(
        User,
        "INSERT INTO users (name, email) VALUES ($1, $2) RETURNING id, name, email, role",
        name, email
    )
    .fetch_one(pool)
    .await
}

/// Delete a user by ID
pub async fn delete_user(pool: &PgPool, id: i32) -> bool {
    let result = sqlx::query!("DELETE FROM users WHERE id = $1", id)
        .execute(pool)
        .await;
    result.map(|r| r.rows_affected() > 0).unwrap_or(false)
}
