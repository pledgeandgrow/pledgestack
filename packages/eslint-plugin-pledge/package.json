{
  "name": "pledgestack-eslint-plugin",
  "version": "0.1.8",
  "description": "ESLint plugin for PledgeStack framework conventions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/estree": "^1.0.0"
  }
}
