{
  "name": "@pledgestack/core",
  "version": "0.0.2",
  "description": "Core framework for PledgeStack — routing, rendering, and build pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "import": "./dist/fs/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@pledgestack/shared": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-server-dom-webpack": "^19.0.0"
  },
  "license": "MIT",
  "author": "PledgeStack Contributors",
  "homepage": "https://github.com/pledgeandgrow/pledgestack#readme",
  "bugs": {
    "url": "https://github.com/pledgeandgrow/pledgestack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledgeandgrow/pledgestack.git",
    "directory": "packages/core"
  },
  "keywords": [
    "pledgestack",
    "react",
    "framework",
    "core",
    "routing",
    "rendering",
    "rsc",
    "ssr"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
