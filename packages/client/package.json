{
  "name": "@pledgestack/client",
  "version": "0.0.2",
  "description": "Client-side hydration and routing runtime for PledgeStack",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./hydrate": {
      "types": "./dist/hydrate.d.ts",
      "import": "./dist/hydrate.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@pledgestack/shared": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-refresh": "^0.16.0"
  },
  "license": "MIT",
  "author": "PledgeStack Contributors",
  "homepage": "https://github.com/pledgeandgrow/pledgestack#readme",
  "bugs": {
    "url": "https://github.com/pledgeandgrow/pledgestack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledgeandgrow/pledgestack.git",
    "directory": "packages/client"
  },
  "keywords": [
    "pledgestack",
    "react",
    "framework",
    "client",
    "hydration",
    "router"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
