{
  "name": "pledgestack-auth",
  "version": "0.0.2",
  "description": "Authentication helpers for PledgeStack — cookie sessions, JWT, OAuth providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pledgestack-shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^22.0.0"
  },
  "license": "MIT",
  "author": "PledgeStack Contributors",
  "homepage": "https://github.com/pledgeandgrow/pledgestack#readme",
  "bugs": {
    "url": "https://github.com/pledgeandgrow/pledgestack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledgeandgrow/pledgestack.git",
    "directory": "packages/auth"
  },
  "keywords": [
    "pledgestack",
    "react",
    "framework",
    "auth",
    "session",
    "csrf",
    "security"
  ],
  "private": true
}
