{
  "name": "pledgestack",
  "version": "0.0.2",
  "description": "A full-stack React framework with file-based routing, SSR, SSG, RSC, API routes, and edge runtime support.",
  "type": "module",
  "bin": {
    "pledge": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    },
    "./state": {
      "import": "./dist/state.js",
      "types": "./dist/state.d.ts"
    },
    "./api": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./a11y": {
      "import": "./dist/a11y.js",
      "types": "./dist/a11y.d.ts"
    },
    "./overlay": {
      "import": "./dist/overlay.js",
      "types": "./dist/overlay.d.ts"
    },
    "./seo": {
      "import": "./dist/seo.js",
      "types": "./dist/seo.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tsconfig-base.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "node scripts/build.mjs --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "pledgepack": "^0.1.1",
    "jiti": "^2.4.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^22.0.0",
    "pledgestack-shared": "workspace:*",
    "pledgestack-core": "workspace:*",
    "pledgestack-server": "workspace:*",
    "pledgestack-client": "workspace:*",
    "pledgestack-auth": "workspace:*",
    "pledgestack-state": "workspace:*",
    "pledgestack-api": "workspace:*",
    "pledgestack-a11y": "workspace:*",
    "pledgestack-overlay": "workspace:*",
    "pledgestack-seo": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "PledgeStack Contributors",
  "homepage": "https://github.com/pledgeandgrow/pledgestack#readme",
  "bugs": {
    "url": "https://github.com/pledgeandgrow/pledgestack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledgeandgrow/pledgestack.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "pledgestack",
    "react",
    "framework",
    "ssr",
    "ssg",
    "rsc",
    "file-based-routing",
    "edge",
    "fullstack",
    "nextjs-alternative"
  ]
}
