{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "pledgestack-core": ["../core/src/index.ts"],
      "pledgestack-core/*": ["../core/src/*"],
      "pledgestack-server": ["../server/src/index.ts"],
      "pledgestack-server/*": ["../server/src/*"],
      "pledgestack-client": ["../client/src/index.ts"],
      "pledgestack-client/*": ["../client/src/*"],
      "pledgestack-shared": ["../shared/src/index.ts"],
      "pledgestack-shared/*": ["../shared/src/*"],
      "pledgestack-auth": ["../auth/src/index.ts"],
      "pledgestack-auth/*": ["../auth/src/*"],
      "pledgestack-state": ["../state/src/index.ts"],
      "pledgestack-state/*": ["../state/src/*"],
      "pledgestack-api": ["../api/src/index.ts"],
      "pledgestack-api/*": ["../api/src/*"],
      "pledgestack-a11y": ["../a11y/src/index.ts"],
      "pledgestack-a11y/*": ["../a11y/src/*"],
      "pledgestack-overlay": ["../overlay/src/index.ts"],
      "pledgestack-overlay/*": ["../overlay/src/*"],
      "pledgestack-seo": ["../seo/src/index.ts"],
      "pledgestack-seo/*": ["../seo/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
