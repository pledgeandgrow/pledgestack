{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "composite": false,
    "paths": {
      "pledgestack-core": ["../core/dist/index.d.ts"],
      "pledgestack-core/*": ["../core/dist/*"],
      "pledgestack-server": ["../server/dist/index.d.ts"],
      "pledgestack-server/*": ["../server/dist/*"],
      "pledgestack-client": ["../client/dist/index.d.ts"],
      "pledgestack-client/*": ["../client/dist/*"],
      "pledgestack-shared": ["../shared/dist/index.d.ts"],
      "pledgestack-shared/*": ["../shared/dist/*"],
      "pledgestack-auth": ["../auth/dist/index.d.ts"],
      "pledgestack-auth/*": ["../auth/dist/*"],
      "pledgestack-state": ["../state/dist/index.d.ts"],
      "pledgestack-state/*": ["../state/dist/*"],
      "pledgestack-api": ["../api/dist/index.d.ts"],
      "pledgestack-api/*": ["../api/dist/*"],
      "pledgestack-a11y": ["../a11y/dist/index.d.ts"],
      "pledgestack-a11y/*": ["../a11y/dist/*"],
      "pledgestack-overlay": ["../overlay/dist/index.d.ts"],
      "pledgestack-overlay/*": ["../overlay/dist/*"],
      "pledgestack-seo": ["../seo/dist/index.d.ts"],
      "pledgestack-seo/*": ["../seo/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
