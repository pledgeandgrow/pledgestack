{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "pledgestack-core": ["../core/src/index.ts"],
      "pledgestack-core/*": ["../core/src/*"],
      "pledgestack-server": ["../server/src/index.ts"],
      "pledgestack-server/*": ["../server/src/*"],
      "pledgestack-client": ["../client/src/index.ts"],
      "pledgestack-client/*": ["../client/src/*"],
      "pledgestack-shared": ["../shared/src/index.ts"],
      "pledgestack-shared/*": ["../shared/src/*"],
      "pledgestack-auth": ["../auth/src/index.ts"],
      "pledgestack-auth/*": ["../auth/src/*"],
      "pledgestack-state": ["../state/src/index.ts"],
      "pledgestack-state/*": ["../state/src/*"],
      "pledgestack-api": ["../api/src/index.ts"],
      "pledgestack-api/*": ["../api/src/*"],
      "pledgestack-a11y": ["../a11y/src/index.ts"],
      "pledgestack-a11y/*": ["../a11y/src/*"],
      "pledgestack-overlay": ["../overlay/src/index.ts"],
      "pledgestack-overlay/*": ["../overlay/src/*"],
      "pledgestack-seo": ["../seo/src/index.ts"],
      "pledgestack-seo/*": ["../seo/src/*"],
      "pledgestack-image": ["../image/src/index.ts"],
      "pledgestack-image/*": ["../image/src/*"],
      "pledgestack-font": ["../font/src/index.ts"],
      "pledgestack-font/*": ["../font/src/*"],
      "pledgestack-mdx": ["../mdx/src/index.ts"],
      "pledgestack-mdx/*": ["../mdx/src/*"],
      "pledgestack-og": ["../og/src/index.ts"],
      "pledgestack-og/*": ["../og/src/*"],
      "pledgestack-sitemap": ["../sitemap/src/index.ts"],
      "pledgestack-sitemap/*": ["../sitemap/src/*"],
      "pledgestack-rss": ["../rss/src/index.ts"],
      "pledgestack-rss/*": ["../rss/src/*"],
      "pledgestack-ws": ["../ws/src/index.ts"],
      "pledgestack-ws/*": ["../ws/src/*"],
      "pledgestack-adapters": ["../adapters/src/index.ts"],
      "pledgestack-adapters/*": ["../adapters/src/*"],
      "pledgestack-privacy": ["../privacy/src/index.ts"],
      "pledgestack-privacy/*": ["../privacy/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
