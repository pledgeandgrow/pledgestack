{
  "name": "@pledgestack/og",
  "version": "0.0.1",
  "private": true,
  "description": "OpenGraph image generation for PledgeStack — dynamic OG images via Satori + resvg",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pledgestack/shared": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/react": "^19.0.0",
    "@types/node": "^22.0.0"
  }
}
