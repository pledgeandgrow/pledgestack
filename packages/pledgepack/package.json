{
  "name": "pledgepack",
  "version": "0.2.3",
  "description": "A Rust+Zig bundler with incremental computation, WASM plugins, and Rollup-quality output",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "pledgepack": "./pledge.js"
  },
  "scripts": {
    "build": "cargo build --release && cp target/release/pledge bin/pledge",
    "dev": "cargo build && cp target/debug/pledge bin/pledge",
    "clean": "cargo clean && rimraf bin",
    "install": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "src/",
    "pledge.js",
    "index.js",
    "index.d.ts",
    "scripts/",
    "Cargo.toml",
    "README.md"
  ],
  "devDependencies": {
    "rimraf": "^6.0.0",
    "@types/node": "^22.0.0"
  },
  "optionalDependencies": {
    "@pledgepack/darwin-arm64": "0.2.3",
    "@pledgepack/darwin-x64": "0.2.3",
    "@pledgepack/linux-x64-gnu": "0.2.3",
    "@pledgepack/win32-x64-msvc": "0.2.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "PledgeStack Contributors",
  "homepage": "https://github.com/pledgeandgrow/pledgestack#readme",
  "bugs": {
    "url": "https://github.com/pledgeandgrow/pledgestack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledgeandgrow/pledgestack.git",
    "directory": "packages/pledgepack"
  },
  "keywords": [
    "pledgepack",
    "bundler",
    "rust",
    "zig",
    "esbuild",
    "incremental",
    "wasm"
  ]
}
