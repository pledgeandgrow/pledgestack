{
  "name": "pledgestack-state",
  "version": "0.0.2",
  "description": "State management for PledgeStack — store, URL state, cross-tab sync, forms, optimistic UI, debugging",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "license": "MIT",
  "author": "PledgeStack Contributors",
  "homepage": "https://github.com/pledgeandgrow/pledgestack#readme",
  "bugs": {
    "url": "https://github.com/pledgeandgrow/pledgestack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pledgeandgrow/pledgestack.git",
    "directory": "packages/state"
  },
  "keywords": [
    "pledgestack",
    "react",
    "framework",
    "state",
    "store",
    "url-state"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
